#!/usr/bin/env bash
set -euo pipefail

PROCESSWIRE_ARCHIVE_URL="https://github.com/processwire/processwire/archive/dev.zip"
PROFILE="site-blank"
MYSQL_CLI="/Applications/MAMP/Library/bin/mysql"
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="8889"
MYSQL_PORT_EXPLICIT="0"
MYSQL_USER="root"
MYSQL_PASS="root"
DOMAIN=""
DB_NAME=""
ADMIN_USER=""
ADMIN_EMAIL=""
ADMIN_PATH=""
ROOT_DIR=""
FORCE="0"
WEB_SCHEME="https"
WEB_PORT=""

usage() {
  cat <<'USAGE'
Usage:
  bash bin/mampwire-install [--domain example.test] [options]

Options:
  --domain DOMAIN        Local MAMP site domain. Inferred from MAMP Pro config when omitted.
  --db-name NAME         Database name. Defaults to a sanitized domain/folder name.
  --mysql-cli PATH       MAMP mysql binary. Auto-detected when omitted.
  --mysql-host HOST      Default: 127.0.0.1
  --mysql-port PORT      Default: 8889
  --mysql-user USER      Default: root
  --mysql-pass PASS      Default: root
  --admin-user USER      Default: same as database name
  --admin-email EMAIL    Default: admin@DOMAIN
  --admin-path PATH      Admin URL segment. Default: generated from Irish names
  --root PATH            Site document root. Default: current folder.
  --force                Allow installing into a folder that already has ProcessWire files.
  -h, --help             Show help.
USAGE
}

fail() {
  printf 'MampWire error: %s\n' "$1" >&2
  exit 1
}

sanitize_db_name() {
  local value="$1"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
  value="$(printf '%s' "$value" | sed -E 's/[^a-z0-9_]+/_/g; s/^_+//; s/_+$//; s/_+/_/g')"
  if [ -z "$value" ]; then
    value="processwire"
  fi
  printf 'pw_%.45s' "$value"
}

random_password() {
  local length="${1:-32}"
  local password=""
  local chunk=""
  while [ "${#password}" -lt "$length" ]; do
    chunk="$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c "$length" || true)"
    password="${password}${chunk}"
  done
  printf '%s' "${password:0:$length}"
}

detect_php() {
  local candidates=()
  while IFS= read -r path; do
    candidates+=("$path")
  done < <(find /Applications/MAMP/bin/php -path '*/bin/php' -type f 2>/dev/null | sort)

  if [ "${#candidates[@]}" -eq 0 ]; then
    fail "MAMP PHP binary was not found in /Applications/MAMP/bin/php."
  fi

  printf '%s' "${candidates[$((${#candidates[@]} - 1))]}"
}

detect_mysql_cli() {
  local candidates=()
  local path
  for path in \
    /Applications/MAMP/Library/bin/mysql \
    /Applications/MAMP/Library/bin/mysql*/bin/mysql \
    /Applications/MAMP/Library/bin/mariadb*/bin/mysql
  do
    [ -x "$path" ] && candidates+=("$path")
  done

  if [ "${#candidates[@]}" -eq 0 ]; then
    fail "MAMP MySQL CLI was not found. Pass --mysql-cli /path/to/mysql."
  fi

  printf '%s' "${candidates[$((${#candidates[@]} - 1))]}"
}

detect_mysql_port() {
  local config="/Applications/MAMP/tmp/mysql/my.cnf"
  [ -f "$config" ] || return 1

  awk '
    /^[[:space:]]*\[client\][[:space:]]*$/ { in_client = 1; next }
    /^[[:space:]]*\[/ { in_client = 0 }
    in_client && /^[[:space:]]*port[[:space:]]*=/ {
      gsub(/[^0-9]/, "", $0)
      if($0 != "") {
        print $0
        exit
      }
    }
  ' "$config"
}

detect_listen_port() {
  local config="$1"
  [ -f "$config" ] || return 1
  awk '
    /^[[:space:]]*Listen[[:space:]]+/ {
      value = $2
      sub(/^.*:/, "", value)
      gsub(/[^0-9]/, "", value)
      if(value != "") {
        print value
        exit
      }
    }
  ' "$config"
}

detect_nginx_listen_port() {
  local config="$1"
  [ -f "$config" ] || return 1
  awk '
    /^[[:space:]]*listen[[:space:]]+/ {
      value = $2
      sub(/^.*:/, "", value)
      gsub(/[^0-9]/, "", value)
      if(value != "") {
        print value
        exit
      }
    }
  ' "$config"
}

detect_web_port() {
  local scheme="${1:-https}"
  local default_port="443"
  local configs=()
  local port=""

  if [ "$scheme" = "http" ]; then
    default_port="80"
    configs=(
      "/Library/Application Support/appsolute/MAMP PRO/conf/httpd.conf"
      "$HOME/Library/Application Support/appsolute/MAMP PRO/httpd.conf"
      "/Library/Application Support/appsolute/MAMP PRO/conf/nginx.conf"
      "$HOME/Library/Application Support/appsolute/MAMP PRO/nginx.conf"
    )
  else
    configs=(
      "/Library/Application Support/appsolute/MAMP PRO/conf/httpd-ssl.conf"
      "$HOME/Library/Application Support/appsolute/MAMP PRO/httpd-ssl.conf"
      "/Library/Application Support/appsolute/MAMP PRO/conf/nginx.conf"
      "$HOME/Library/Application Support/appsolute/MAMP PRO/nginx.conf"
    )
  fi

  local config
  for config in "${configs[@]}"; do
    case "$config" in
      *nginx.conf)
        port="$(detect_nginx_listen_port "$config" || true)"
        ;;
      *)
        port="$(detect_listen_port "$config" || true)"
        ;;
    esac
    [ -n "$port" ] && break
  done

  [ -n "$port" ] || port="$default_port"
  printf '%s' "$port"
}

build_site_url() {
  local scheme="$1"
  local domain="$2"
  local port="$3"
  local default_port="443"
  [ "$scheme" = "http" ] && default_port="80"

  if [ -n "$port" ] && [ "$port" != "$default_port" ]; then
    printf '%s://%s:%s' "$scheme" "$domain" "$port"
  else
    printf '%s://%s' "$scheme" "$domain"
  fi
}

generate_irish_admin_path() {
  local names=(
    aine aoife brigid caoimhe ciaran conor declan eamon fergus
    fionn maeve niall niamh oisin orla ronan roisin saoirse
    seamus siobhan sorcha tadgh
  )
  local name="${names[$((RANDOM % ${#names[@]}))]}"
  local suffix
  suffix="$(random_password 4 | tr '[:upper:]' '[:lower:]')"
  printf '%s-%s' "$name" "$suffix"
}

normalize_path() {
  local path="$1"
  (cd "$path" 2>/dev/null && pwd -P) || return 1
}

infer_domain_from_mamp() {
  local root="$1"
  local normalized_root
  normalized_root="$(normalize_path "$root")" || return 1

  local configs=(
    "/Library/Application Support/appsolute/MAMP PRO/conf/httpd.conf"
    "/Library/Application Support/appsolute/MAMP PRO/conf/nginx.conf"
  )

  local config
  for config in "${configs[@]}"; do
    [ -f "$config" ] || continue
    MAMPWIRE_ROOT="$normalized_root" perl -MFile::Spec -MCwd -0ne '
      sub norm {
        my ($path) = @_;
        return "" unless defined $path && length $path;
        $path =~ s/^\s+|\s+$//g;
        $path =~ s/^"|"//g;
        my $abs = File::Spec->rel2abs($path);
        return Cwd::realpath($abs) || $abs;
      }
      my $root = $ENV{"MAMPWIRE_ROOT"};
      while(/<VirtualHost\b[^>]*>(.*?)<\/VirtualHost>/sg) {
        my $block = $1;
        next unless $block =~ /DocumentRoot\s+"?([^"\n]+)"?/i;
        my $docroot = norm($1);
        next unless $docroot eq $root;
        if($block =~ /ServerName\s+([^\s]+)/i) {
          print "$1\n";
          exit 0;
        }
      }
      while(/server\s*\{(.*?)\}/sg) {
        my $block = $1;
        next unless $block =~ /\broot\s+([^;\n]+);/i;
        my $docroot = norm($1);
        next unless $docroot eq $root;
        if($block =~ /server_name\s+([^;\s]+)/i) {
          print "$1\n";
          exit 0;
        }
      }
    ' "$config" | head -n 1
  done
}

copy_processwire_files() {
  local source_dir="$1"
  local target_dir="$2"

  if command -v rsync >/dev/null 2>&1; then
    rsync -a "$source_dir"/ "$target_dir"/
  else
    (cd "$source_dir" && tar cf - .) | (cd "$target_dir" && tar xf -)
  fi
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --domain)
      DOMAIN="${2:-}"
      shift 2
      ;;
    --db-name)
      DB_NAME="${2:-}"
      shift 2
      ;;
    --mysql-cli)
      MYSQL_CLI="${2:-}"
      shift 2
      ;;
    --mysql-host)
      MYSQL_HOST="${2:-}"
      shift 2
      ;;
    --mysql-port)
      MYSQL_PORT="${2:-}"
      MYSQL_PORT_EXPLICIT="1"
      shift 2
      ;;
    --mysql-user)
      MYSQL_USER="${2:-}"
      shift 2
      ;;
    --mysql-pass)
      MYSQL_PASS="${2:-}"
      shift 2
      ;;
    --admin-user)
      ADMIN_USER="${2:-}"
      shift 2
      ;;
    --admin-email)
      ADMIN_EMAIL="${2:-}"
      shift 2
      ;;
    --admin-path)
      ADMIN_PATH="${2:-}"
      shift 2
      ;;
    --root)
      ROOT_DIR="${2:-}"
      shift 2
      ;;
    --force)
      FORCE="1"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "Unknown option: $1"
      ;;
  esac
done

command -v curl >/dev/null 2>&1 || fail "curl is required."
command -v unzip >/dev/null 2>&1 || fail "unzip is required."

if [ -z "$MYSQL_CLI" ] || [ ! -x "$MYSQL_CLI" ]; then
  MYSQL_CLI="$(detect_mysql_cli)"
fi

if [ "$MYSQL_PORT_EXPLICIT" = "0" ]; then
  DETECTED_MYSQL_PORT="$(detect_mysql_port || true)"
  if [ -n "$DETECTED_MYSQL_PORT" ]; then
    MYSQL_PORT="$DETECTED_MYSQL_PORT"
  fi
fi

ROOT_DIR="${ROOT_DIR:-$(pwd)}"
ROOT_DIR="$(normalize_path "$ROOT_DIR")" || fail "Site root does not exist: $ROOT_DIR"

if [ -z "$DOMAIN" ]; then
  DOMAIN="$(infer_domain_from_mamp "$ROOT_DIR" | head -n 1 || true)"
fi

[ -n "$DOMAIN" ] || fail "Could not infer the MAMP Pro domain for $ROOT_DIR. Pass --domain example.test."
PHP_BIN="$(detect_php)"
ADMIN_EMAIL="${ADMIN_EMAIL:-admin@$DOMAIN}"
WEB_PORT="$(detect_web_port "$WEB_SCHEME")"
SITE_URL="$(build_site_url "$WEB_SCHEME" "$DOMAIN" "$WEB_PORT")"

if [ -z "$DB_NAME" ]; then
  DB_NAME="$(sanitize_db_name "$DOMAIN")"
fi

ADMIN_USER="${ADMIN_USER:-$DB_NAME}"
ADMIN_PATH="${ADMIN_PATH:-$(generate_irish_admin_path)}"

if ! printf '%s' "$DB_NAME" | grep -Eq '^[A-Za-z0-9_]+$'; then
  fail "Database name may contain only letters, numbers, and underscores."
fi

if [ -f "$ROOT_DIR/site/assets/installed.php" ] && [ "$FORCE" != "1" ]; then
  fail "ProcessWire appears to be installed already. Use --force only if you want to reinstall."
fi

if [ "$FORCE" != "1" ]; then
  for item in wire index.php install.php site; do
    if [ -e "$ROOT_DIR/$item" ]; then
      fail "Found existing $item. Use --force only if you want to install over existing files."
    fi
  done
fi

printf 'Checking MAMP MySQL connection...\n'
if ! "$MYSQL_CLI" \
  -h"$MYSQL_HOST" \
  -P"$MYSQL_PORT" \
  -u"$MYSQL_USER" \
  -p"$MYSQL_PASS" \
  -e "SELECT 1;" >/dev/null 2>&1; then
  if [ "$MYSQL_PORT_EXPLICIT" = "0" ] && [ "$MYSQL_PORT" = "8889" ]; then
    MYSQL_PORT="3306"
    printf 'MySQL did not answer on 8889; trying 3306...\n'
    "$MYSQL_CLI" \
      -h"$MYSQL_HOST" \
      -P"$MYSQL_PORT" \
      -u"$MYSQL_USER" \
      -p"$MYSQL_PASS" \
      -e "SELECT 1;" >/dev/null
  else
    fail "MySQL is not reachable at $MYSQL_HOST:$MYSQL_PORT."
  fi
fi

printf 'Creating database %s if needed...\n' "$DB_NAME"
"$MYSQL_CLI" \
  -h"$MYSQL_HOST" \
  -P"$MYSQL_PORT" \
  -u"$MYSQL_USER" \
  -p"$MYSQL_PASS" \
  -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"

TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/mampwire.XXXXXX")"
cleanup_tmp() {
  rm -rf "$TMP_DIR"
}
trap cleanup_tmp EXIT

printf 'Downloading ProcessWire dev...\n'
curl -fsSL "$PROCESSWIRE_ARCHIVE_URL" -o "$TMP_DIR/processwire-dev.zip"

printf 'Extracting ProcessWire...\n'
unzip -q "$TMP_DIR/processwire-dev.zip" -d "$TMP_DIR/extract"
SOURCE_DIR="$(find "$TMP_DIR/extract" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
[ -n "$SOURCE_DIR" ] || fail "Could not find extracted ProcessWire directory."

if ! grep -q 'class InstallerCli' "$SOURCE_DIR/install.php"; then
  fail "Downloaded ProcessWire dev installer does not include InstallerCli."
fi

printf 'Copying ProcessWire files into %s...\n' "$ROOT_DIR"
copy_processwire_files "$SOURCE_DIR" "$ROOT_DIR"

ADMIN_PASSWORD="$(random_password 32)"
CONFIG_FILE="$ROOT_DIR/install-config.php"

cat > "$CONFIG_FILE" <<PHP
<?php
return [
  'profile' => '$PROFILE',
  'dbName' => '$DB_NAME',
  'dbUser' => '$MYSQL_USER',
  'dbPass' => '$MYSQL_PASS',
  'dbHost' => '$MYSQL_HOST',
  'dbPort' => '$MYSQL_PORT',
  'dbCon' => 'Hostname',
  'dbEngine' => 'InnoDB',
  'dbCharset' => 'utf8mb4',
  'timezone' => 'UTC',
  'httpHosts' => ['$DOMAIN'],
  'debugMode' => 1,
  'admin_name' => '$ADMIN_PATH',
  'username' => '$ADMIN_USER',
  'useremail' => '$ADMIN_EMAIL',
  'userpass' => '$ADMIN_PASSWORD',
  'userpass_confirm' => '$ADMIN_PASSWORD',
];
PHP
chmod 600 "$CONFIG_FILE"

printf 'Running ProcessWire CLI installer...\n'
set +e
INSTALL_OUTPUT="$("$PHP_BIN" install.php --config install-config.php 2>&1)"
INSTALL_CODE="$?"
set -e
rm -f "$CONFIG_FILE"

if [ "$INSTALL_CODE" -ne 0 ]; then
  printf '%s\n' "$INSTALL_OUTPUT" >&2
  fail "ProcessWire CLI installer failed."
fi

printf 'Cleaning installer files...\n'
set +e
CLEANUP_OUTPUT="$("$PHP_BIN" install.php --cleanup 2>&1)"
CLEANUP_CODE="$?"
set -e
if [ "$CLEANUP_CODE" -ne 0 ] && [ -f "$ROOT_DIR/install.php" ]; then
  printf '%s\n' "$CLEANUP_OUTPUT" >&2
  fail "ProcessWire cleanup failed."
fi

mkdir -p "$ROOT_DIR/.local"
chmod 700 "$ROOT_DIR/.local"
cat > "$ROOT_DIR/.local/admin.md" <<MD
# Local ProcessWire Admin

Site URL: $SITE_URL/
Admin URL: $SITE_URL/$ADMIN_PATH/

Admin user: $ADMIN_USER
Admin password: $ADMIN_PASSWORD
Admin email: $ADMIN_EMAIL

Database host: $MYSQL_HOST
Database port: $MYSQL_PORT
Database name: $DB_NAME
Database user: $MYSQL_USER
Database password: $MYSQL_PASS

PHP binary: $PHP_BIN
ProcessWire source: $PROCESSWIRE_ARCHIVE_URL
MD
chmod 600 "$ROOT_DIR/.local/admin.md"

printf '\nProcessWire dev installed.\n'
printf 'Admin URL: %s/%s/\n' "$SITE_URL" "$ADMIN_PATH"
printf 'Credentials: %s\n' "$ROOT_DIR/.local/admin.md"
